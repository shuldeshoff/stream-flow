# Настройки сервера
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30

# Настройки gRPC
GRPC_PORT=9000

# Настройки процессора
WORKER_COUNT=10
BUFFER_SIZE=10000
BATCH_SIZE=1000
FLUSH_TIMEOUT=5

# Настройки ClickHouse
CLICKHOUSE_ADDRESS=localhost:9000
CLICKHOUSE_DATABASE=streamflow
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_TABLE=events

# Настройки Redis
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Настройки Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000

# Настройки метрик
METRICS_PORT=9090

# TLS/SSL Configuration
TLS_ENABLED=false
TLS_CERT_FILE=./certs/server-cert.pem
TLS_KEY_FILE=./certs/server-key.pem
TLS_CA_FILE=
# Для mTLS (mutual TLS) установите TLS_CA_FILE=./certs/ca-cert.pem

# JWT Authentication
JWT_ENABLED=false
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=streamflow

